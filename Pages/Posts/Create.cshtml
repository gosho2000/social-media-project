@page "/Posts/Create"
@model CourseSocialMedia.Pages.NonAdmin.Posts.CreateModel


		<form method="POST" action="/Posts/Create">
		<div class="mt-3">
			<label for="CommentTitle" class="form-label">Title:</label>
			<input type="text" class="form-control" name="PostTitle" id="CommentTitle"/>
			<label for="CommentTextArea" class="form-label">Post:</label>
			<textarea class="form-control" name="PostBody" id="CommentTextArea" rows="3"></textarea>
			<button class="btn btn-primary mt-3" type="submit">Submit</button>
		</div>
		@Html.AntiForgeryToken()
		</form>
